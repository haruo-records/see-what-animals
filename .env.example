# Public site URL (used for metadata, sitemap, OGP). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://see-what.example

# Existing animals archive (source of truth for the works)
NEXT_PUBLIC_ANIMALS_ARCHIVE_URL=https://haruo-records.github.io/animals-site/

# Analytics (optional — leave empty to disable). Added later without code changes.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# --- Anonymous observation analytics (Supabase) ---
# SERVER-ONLY. Never expose the service role key to the browser.
# Get these from Supabase → Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: override the game version reported with each answer (defaults to 1.0.0)
NEXT_PUBLIC_GAME_VERSION=
# Optional (dev only): country code to use when Vercel's geo header is absent.
# Ignored in production. e.g. DEV_FALLBACK_COUNTRY=JP
DEV_FALLBACK_COUNTRY=

# External project links shown quietly under the profile on the Support page.
NEXT_PUBLIC_NOTE_URL=https://note.com/
NEXT_PUBLIC_SUBSTACK_URL=https://substack.com/

# --- Support (Stripe Payment Links) ---
# Create ONE Payment Link per tier in the Stripe Dashboard, then paste its URL
# here. 100 / 300 = one-time; 500+ = monthly (recurring). Leave a value blank to
# hide that tier (the page never shows a broken button). To migrate to Stripe
# Checkout / Elements later, change only components/support/support-options.tsx.
NEXT_PUBLIC_STRIPE_ONCE_100=
NEXT_PUBLIC_STRIPE_ONCE_300=
NEXT_PUBLIC_STRIPE_MONTHLY_500=
NEXT_PUBLIC_STRIPE_MONTHLY_1000=
NEXT_PUBLIC_STRIPE_MONTHLY_3000=
NEXT_PUBLIC_STRIPE_MONTHLY_10000=
NEXT_PUBLIC_STRIPE_MONTHLY_100000=
# A single "customer chooses price" Payment Link (monthly) for Custom amount.
NEXT_PUBLIC_STRIPE_CUSTOM=
# Optional quiet fallback contact shown on the Support page.
NEXT_PUBLIC_SUPPORT_EMAIL=

# --- One-word observation → AI 2-word naming ---
# Provider is swappable in one place (lib/naming/provider.ts).
NAMING_PROVIDER=openai            # openai | anthropic
NAMING_MODEL=                     # optional override (default: gpt-4o-mini / claude-3-5-haiku-latest)
OPENAI_API_KEY=                   # required when NAMING_PROVIDER=openai
ANTHROPIC_API_KEY=                # required when NAMING_PROVIDER=anthropic
# Protects the naming cron. Vercel Cron sends "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

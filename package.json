{
  "name": "see-what",
  "version": "0.1.0",
  "private": true,
  "description": "See What? \u2014 an observation project. Observation is a luxury.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,css,md}\"",
    "generator:generate": "tsx generator/scripts/generate-candidates.ts",
    "generator:preview": "tsx generator/scripts/build-gallery.ts",
    "generator:register": "tsx generator/scripts/register-work.ts",
    "generator:module-create": "tsx generator/scripts/create-module.ts",
    "generator:validate": "tsx generator/scripts/validate-generator.ts",
    "generator:test": "tsx --test generator/tests/*.test.ts",
    "generator:prototypes": "tsx generator/scripts/build-prototypes.ts"
  },
  "dependencies": {
    "next": "^14.2.30",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.2.30",
    "postcss": "8.4.39",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.6",
    "tsx": "4.19.2",
    "typescript": "5.5.3"
  }
}
